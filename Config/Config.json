{
  "server": {
    "name": "tamanna.io",
    "host": "0.0.0.0",
    "port": 8080,
    "protocol": "https"
  },

  "security": {
    "rateLimit": true,
    "maxRequestsPerMinute": 1200,
    "enableCORS": true,
    "allowedOrigins": ["https://tamanna.io"],
    "helmet": true
  },

  "database": {
    "enabled": false,
    "type": "none",
    "connection": ""
  },

  "logging": {
    "level": "info",
    "saveLogs": true,
    "logDirectory": "logs/",
    "timestamp": true
  },

  "meta": {
    "version": "1.0.0",
    "author": "HM INSAN ALI",
    "system": "BD KING R7",
    "description": "Sovereign server configuration for Tamanna Engine"
  }
}
